{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimpleML",
  "version": "0.1.0",
  "identifier": "dev.simpleml.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ./frontend dev",
    "beforeBuildCommand": "pnpm --dir ./frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SimpleML — ML Trainer",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
